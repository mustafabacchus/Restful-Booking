    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set(\"firstname\", pm.variables.replaceIn('{{$randomFirstName}}'));",
              "",
              "pm.variables.set(\"lastname\", pm.variables.replaceIn('{{$randomLastName}}'));",
              "",
              "pm.variables.set(\"totalprice\", Math.floor(Math.random() * 2500) + 1);",
              "",
              "pm.variables.set(\"depositPaid\", Math.random() < 0.5);",
              "",
              "//Generate dates",
              "let checkinDate = new Date();",
              "checkinDate.setDate(checkinDate.getDate() + Math.floor(Math.random() * 31));",
              "let checkoutDate = new Date();",
              "checkoutDate.setDate(checkinDate.getDate() + Math.floor(Math.random() * 90) + 1);",
              "//Format dates",
              "let checkin = checkinDate.toISOString().split('T')[0];",
              "let checkout = checkoutDate.toISOString().split('T')[0];",
              "pm.variables.set(\"checkin\", checkin);",
              "pm.variables.set(\"checkout\", checkout);",
              "",
              "pm.variables.set(\"additionalneeds\", pm.variables.replaceIn('{{$randomLoremSentence}}'));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.unset();"
            ],
