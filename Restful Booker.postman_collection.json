    {
      "name": "Partial Update Booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let updates = {};",
              "",
              "if (Math.random() < 0.5) {",
              "    updates.firstname = pm.variables.replaceIn('{{$randomFirstName}}');",
              "}",
              "if (Math.random() < 0.5) {",
              "    updates.lastname = pm.variables.replaceIn('{{$randomLastName}}');",
              "}",
              "if (Math.random() < 0.5) {",
              "    updates.depositpaid = Math.random() < 0.5;",
              "}",
              "if (Math.random() < 0.5) {",
              "    updates.totalprice = Math.floor(Math.random() * 2500) + 1;",
              "}",
              "if (Math.random() < 0.5) {",
              "    //Generate dates",
              "    let checkinDate = new Date();",
              "    checkinDate.setDate(checkinDate.getDate() + Math.floor(Math.random() * 31));",
              "    let checkoutDate = new Date();",
              "    checkoutDate.setDate(checkinDate.getDate() + Math.floor(Math.random() * 90) + 1);",
              "    //Format dates",
              "    let checkin = checkinDate.toISOString().split('T')[0];",
              "    let checkout = checkoutDate.toISOString().split('T')[0];",
              "    updates.bookingdates = {",
              "        \"checkin\": checkin,",
              "        \"checkout\": checkout};",
              "}",
              "if (Math.random() < 0.5) {",
              "    updates.additionalneeds = pm.variables.replaceIn('{{$randomLoremSentence}}');",
              "}",
              "",
              "pm.variables.set(\"booking_patch\", JSON.stringify(updates));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
